# Mesmo projeto Supabase do Social Jurídico (precisa de service role para
# poder atualizar advogados.oab_verification_status sem RLS).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (chave REAL da OpenAI, formato sk-...). NÃO deixar OPENAI_BASE_URL
# setado apontando para endpoint Gemini-compat — deixar vazio usa o
# endpoint oficial api.openai.com.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Chave compartilhada usada pelo app principal (socialjuridico) para
# autenticar as chamadas a esta API (header: x-api-key).
VERIFICACAO_API_KEY=

# Origem permitida para CORS (o app principal)
ALLOWED_ORIGIN=https://www.socialjuridico.com.br

# URL pública desta API (usada para montar o link /verificar/{sessao_id}
# devolvido em POST /api/sessoes). Em produção: https://validacao.socialjuridico.com.br
PUBLIC_BASE_URL=http://localhost:3100

# Segredo usado para assinar (HMAC) os webhooks enviados ao app principal
# quando uma sessão de verificação termina.
WEBHOOK_SIGNING_SECRET=
